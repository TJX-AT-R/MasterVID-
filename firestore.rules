rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'student')
    //   - createdAt: timestamp (required)
    //
    // Collection: payments
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - referenceCode: string (required, max 20 chars)
    //   - amount: number (required, must be 5)
    //   - status: string (required, 'pending', 'verified', 'rejected')
    //   - createdAt: timestamp (required)
    //   - verifiedAt: timestamp (optional)
    //
    // Collection: resources
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - fileUrl: string (required)
    //   - imageUrl: string (optional)
    //   - price: number (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "ncubethubelihle483@gmail.com")
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'student'] &&
             data.createdAt is timestamp;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['uid', 'email', 'referenceCode', 'amount', 'status', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.referenceCode is string && data.referenceCode.size() > 0 && data.referenceCode.size() <= 20 &&
             data.amount is number &&
             data.status in ['pending', 'verified', 'rejected'] &&
             data.createdAt is timestamp;
    }

    function isValidResource(data) {
      return data.keys().hasAll(['title', 'description', 'fileUrl', 'price', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 500 &&
             data.fileUrl is string &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             data.price is number && data.price >= 0 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'student' || isAdmin());
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && isValidUser(request.resource.data));
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && isValidPayment(request.resource.data) && 
                    request.resource.data.uid == request.auth.uid && 
                    request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidPayment(request.resource.data);
      allow delete: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidResource(request.resource.data);
    }
  }
}
